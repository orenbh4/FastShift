{
  "version": 2,
  "builds": [
    {
      "src": "api/[...path].cjs",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].cjs"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.svg"
    },
    {
      "src": "/favicon.png",
      "dest": "/public/favicon.svg"
    },
    {
      "src": "/(index\\.html|app\\.js|styles\\.css|favicon\\.svg)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}

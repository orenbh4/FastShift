# Local development defaults
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fastshift
DB_SSL=false

# Production on Vercel + Supabase
# Do not use Docker in production.
# Set these in Vercel Environment Variables:
# NODE_ENV=production
# APP_BASE_URL=https://your-vercel-domain.vercel.app
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
# POSTGRES_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
# DATABASE_POOL_MAX=5

SESSION_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL_HOURS=12
CORS_ORIGINS=

# SMTP provider settings. Use a real provider account in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="FastShift <no-reply@fastshift.local>"

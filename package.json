{
  "name": "fastshift-project",
  "version": "1.0.0",
  "description": "FastShift shift management app with Vercel API routes, Supabase PostgreSQL, and email verification.",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
